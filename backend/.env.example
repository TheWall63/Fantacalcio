# Database PostgreSQL. In locale puoi usare lo stesso progetto Neon gratuito
# che usi in produzione, oppure un Postgres locale/Docker.
# Formato: postgresql://utente:password@host/nome-database?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT secret used to sign auth tokens - change this in production
JWT_SECRET="change-me-to-a-long-random-string"

# Server port
PORT=4000

# football-data.org API key (free tier).
# Get one for free at https://www.football-data.org/client/register
# Serie A (competition code "SA") is included in the free plan.
# Without a key the app runs in DEMO mode with simulated live matches.
FOOTBALL_DATA_API_KEY=

# CORS origin allowed to call this API (the frontend dev server, or in
# produzione l'URL del frontend su Vercel, es. https://tuosito.vercel.app)
CORS_ORIGIN="http://localhost:5173"
