# Database (SQLite file, no external DB server required)
DATABASE_URL="file:./dev.db"

# JWT secret used to sign auth tokens - change this in production
JWT_SECRET="change-me-to-a-long-random-string"

# Server port
PORT=4000

# football-data.org API key (free tier).
# Get one for free at https://www.football-data.org/client/register
# Serie A (competition code "SA") is included in the free plan.
# Without a key the app runs in DEMO mode with simulated live matches.
FOOTBALL_DATA_API_KEY=

# CORS origin allowed to call this API (the frontend dev server)
CORS_ORIGIN="http://localhost:5173"
