// Fantacalcio - schema dati (PostgreSQL, es. Neon in produzione)
// I campi "tipo/stato/ruolo" restano stringhe validate a livello applicativo
// (vedi src/types) per semplicita' e portabilita', non enum nativi Prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nome         String
  createdAt    DateTime @default(now())

  legheCreate Lega[]    @relation("LegaAdmin")
  squadre     Squadra[]
}

model Lega {
  id             String   @id @default(cuid())
  nome           String
  codiceInvito   String   @unique
  stagione       String   @default("2025/26")
  budgetIniziale Int      @default(500)
  numeroGiornate Int      @default(38)
  adminId        String
  createdAt      DateTime @default(now())

  // Impostazioni scelte dall'admin nel wizard subito dopo la creazione della lega.
  moduliConsentiti      String[] @default(["3-4-3", "3-5-2", "4-3-3", "4-4-2", "4-5-1", "5-3-2", "5-4-1"])
  modificatoreDifesa    Boolean  @default(false)
  bonusMvp              Boolean  @default(false)
  cartebonusAttive      Boolean  @default(true)
  // SCONTRI_DIRETTI: round robin, classifica a punti-partita (3/1/0).
  // PUNTI: nessuno scontro diretto, vince chi somma piu' fantapunti in stagione.
  modalitaClassifica    String   @default("SCONTRI_DIRETTI")
  impostazioniCompletate Boolean @default(false)

  // Mercato: finestra temporale (max 1 mese) in cui l'admin gestisce le rose
  // di tutte le squadre e i partecipanti possono scambiarsi giocatori.
  mercatoAperto      Boolean   @default(false)
  mercatoChiusuraAt  DateTime?

  admin      User             @relation("LegaAdmin", fields: [adminId], references: [id])
  squadre    Squadra[]
  calendario Scontro[]
  scambi     RichiestaScambio[]
}

model Squadra {
  id            String   @id @default(cuid())
  nome          String
  legaId        String
  userId        String
  budgetResiduo Int
  createdAt     DateTime @default(now())

  lega         Lega            @relation(fields: [legaId], references: [id], onDelete: Cascade)
  utente       User            @relation(fields: [userId], references: [id])
  rosa         RosaGiocatore[]
  formazioni   Formazione[]
  scontriCasa  Scontro[]       @relation("ScontroCasa")
  scontriFuori Scontro[]       @relation("ScontroTrasferta")
  carteBonus   CartaBonus[]
  scambiProposti  RichiestaScambio[] @relation("ScambioProponente")
  scambiRicevuti  RichiestaScambio[] @relation("ScambioRicevente")

  @@unique([legaId, userId])
}

model Giocatore {
  id             String  @id @default(cuid())
  nome           String
  squadraSerieA  String
  ruolo          String // P | D | C | A
  quotazione     Int? // importata da listone CSV, opzionale
  immagineUrl    String? // URL o path statico dell'immagine del "campioncino", opzionale
  externalTeamId Int? // id squadra su football-data.org, per matching live
  attivo         Boolean @default(true)

  rosa       RosaGiocatore[]
  formazioni FormazioneGiocatore[]
  punteggi   PunteggioGiocatore[]
  carteBonus CartaBonus[]
  scambiOfferti  RichiestaScambio[] @relation("ScambioOfferto")
  scambiRichiesti RichiestaScambio[] @relation("ScambioRichiesto")

  @@index([squadraSerieA])
  @@index([ruolo])
}

model RosaGiocatore {
  id           String   @id @default(cuid())
  squadraId    String
  giocatoreId  String
  prezzoPagato Int      @default(0)
  createdAt    DateTime @default(now())

  squadra   Squadra   @relation(fields: [squadraId], references: [id], onDelete: Cascade)
  giocatore Giocatore @relation(fields: [giocatoreId], references: [id])

  @@unique([squadraId, giocatoreId])
}

model Giornata {
  id         String    @id @default(cuid())
  numero     Int
  stagione   String    @default("2025/26")
  stato      String    @default("PROGRAMMATA") // PROGRAMMATA | IN_CORSO | CONCLUSA
  dataInizio DateTime?
  dataFine   DateTime?

  partite         Partita[]
  punteggi        PunteggioGiocatore[]
  formazioni      Formazione[]
  scontri         Scontro[]
  carteAperte     CartaBonus[]         @relation("CartaApertura")
  carteUtilizzate CartaBonus[]         @relation("CartaUtilizzo")

  @@unique([numero, stagione])
}

model Partita {
  id           String    @id @default(cuid())
  giornataId   String
  externalId   Int?      @unique // id su football-data.org
  squadraCasa  String
  squadraTrasf String
  golCasa      Int?
  golTrasf     Int?
  stato        String    @default("SCHEDULED") // SCHEDULED | LIVE | FINISHED
  dataOra      DateTime?
  aggiornatoAt DateTime  @updatedAt

  giornata Giornata        @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  eventi   EventoPartita[]
}

model EventoPartita {
  id          String  @id @default(cuid())
  partitaId   String
  giocatoreId String?
  tipo        String // GOL | AUTOGOL | ASSIST | AMMONIZIONE | ESPULSIONE | RIGORE_SEGNATO | RIGORE_SBAGLIATO | RIGORE_PARATO
  minuto      Int?
  squadra     String // nome squadra a cui si riferisce l'evento

  partita Partita @relation(fields: [partitaId], references: [id], onDelete: Cascade)
}

model PunteggioGiocatore {
  id           String   @id @default(cuid())
  giornataId   String
  giocatoreId  String
  punti        Float    @default(6) // base 6 + bonus/malus da eventi
  dettaglio    String? // JSON string col dettaglio del calcolo
  // TITOLARE | SUBENTRATO | NON_CONVOCATO | INFORTUNATO — usato per lo schema
  // colorato dello storico partite del giocatore (vedi lib/presenza.ts).
  presenza     String   @default("NON_CONVOCATO")
  aggiornatoAt DateTime @updatedAt

  giornata  Giornata  @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  giocatore Giocatore @relation(fields: [giocatoreId], references: [id])

  @@unique([giornataId, giocatoreId])
}

model Formazione {
  id         String   @id @default(cuid())
  squadraId  String
  giornataId String
  modulo     String   @default("3-4-3")
  punteggio  Float? // calcolato quando la giornata si conclude
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  squadra   Squadra               @relation(fields: [squadraId], references: [id], onDelete: Cascade)
  giornata  Giornata              @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  giocatori FormazioneGiocatore[]

  @@unique([squadraId, giornataId])
}

model FormazioneGiocatore {
  id           String @id @default(cuid())
  formazioneId String
  giocatoreId  String
  slot         String // TITOLARE | PANCHINA
  ordine       Int    @default(0) // ordine in panchina per eventuali sostituzioni

  formazione Formazione @relation(fields: [formazioneId], references: [id], onDelete: Cascade)
  giocatore  Giocatore  @relation(fields: [giocatoreId], references: [id])

  @@unique([formazioneId, giocatoreId])
}

// Pacchetto settimanale "campioncino": una volta per giornata ogni squadra puo'
// aprire un pacchetto ed estrarre un giocatore casuale dalla propria rosa. Se
// quel giocatore gioca da titolare riceve +1 al punteggio finale della
// giornata in cui viene schierato; se non gioca, la carta resta PENDING e si
// attiva automaticamente alla prima giornata utile in cui viene schierato.
model CartaBonus {
  id                 String   @id @default(cuid())
  squadraId          String
  giocatoreId        String
  giornataAperturaId String
  stato              String   @default("PENDING") // PENDING | USATA
  giornataUtilizzoId String?
  createdAt          DateTime @default(now())

  squadra          Squadra   @relation(fields: [squadraId], references: [id], onDelete: Cascade)
  giocatore        Giocatore @relation(fields: [giocatoreId], references: [id])
  giornataApertura Giornata  @relation("CartaApertura", fields: [giornataAperturaId], references: [id])
  giornataUtilizzo Giornata? @relation("CartaUtilizzo", fields: [giornataUtilizzoId], references: [id])

  @@unique([squadraId, giornataAperturaId])
}

// Proposta di scambio tra due squadre della stessa lega, valida solo mentre
// il "Mercato" della lega e' aperto. differenzaCrediti e' quanto la squadra
// proponente da' (positivo) o riceve (negativo) in crediti oltre allo scambio
// dei due giocatori, per bilanciare offerte impari.
model RichiestaScambio {
  id                  String   @id @default(cuid())
  legaId              String
  squadraProponenteId String
  squadraRiceventeId  String
  giocatoreOffertoId  String
  giocatoreRichiestoId String
  differenzaCrediti   Int      @default(0)
  stato               String   @default("PENDING") // PENDING | ACCETTATA | RIFIUTATA | ANNULLATA
  createdAt           DateTime @default(now())
  aggiornatoAt        DateTime @updatedAt

  lega              Lega      @relation(fields: [legaId], references: [id], onDelete: Cascade)
  squadraProponente Squadra   @relation("ScambioProponente", fields: [squadraProponenteId], references: [id], onDelete: Cascade)
  squadraRicevente  Squadra   @relation("ScambioRicevente", fields: [squadraRiceventeId], references: [id], onDelete: Cascade)
  giocatoreOfferto  Giocatore @relation("ScambioOfferto", fields: [giocatoreOffertoId], references: [id])
  giocatoreRichiesto Giocatore @relation("ScambioRichiesto", fields: [giocatoreRichiestoId], references: [id])
}

// Calendario a girone all'italiana: scontri diretti tra squadre della lega
model Scontro {
  id             String @id @default(cuid())
  legaId         String
  giornataId     String
  squadraCasaId  String
  squadraTrasfId String
  punteggioCasa  Float?
  punteggioTrasf Float?

  lega         Lega     @relation(fields: [legaId], references: [id], onDelete: Cascade)
  giornata     Giornata @relation(fields: [giornataId], references: [id], onDelete: Cascade)
  squadraCasa  Squadra  @relation("ScontroCasa", fields: [squadraCasaId], references: [id])
  squadraTrasf Squadra  @relation("ScontroTrasferta", fields: [squadraTrasfId], references: [id])

  @@unique([giornataId, squadraCasaId, squadraTrasfId])
}
